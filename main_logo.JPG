a {  font-family: Verdana, Arial, Helvetica, sans-serif; text-decoration: none; color: #FF0000; font-size: 10pt}
a:hover {  font-family: Verdana, Arial, Helvetica, sans-serif; color: #FF6666; font-size: 10pt}
.text {  font-family: Verdana, Arial, Helvetica, sans-serif; font-size: 11pt}
.textS {  font-family: Verdana, Arial, Helvetica, sans-serif; font-size: 10pt}